{
  "manifest_version": 3,
  "name": "PasteKit Lab",
  "version": "1.0.2",
  "description": "Paste anything. Watch the magic happen.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PasteKit Lab"
  },
  "options_page": "options.html",
  "devtools_page": "devtools.html",
  "icons": {
    "16": "PasteKitLab_16.png",
    "32": "PasteKitLab_32.png",
    "64": "PasteKitLab_64.png",
    "128": "PasteKitLab_128.png"
  },
  "permissions": [
    "commands",
    "activeTab",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "storage"
  ],
  "host_permissions": [
    "https://localhost:8443/*",
    "https://free.freeipapi.com/",
    "https://dns.alidns.com/"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+A"
      },
      "description": "Open PasteKitLab popup"
    },
    "open-options": {
      "suggested_key": {
        "default": "Alt+Shift+Z"
      },
      "description": "Open PasteKitLab options page"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https: http:; frame-src 'self'; child-src 'self';"
  },
  "background": {
    "service_worker": "background.js"
  }

}