{
  "manifest_version": 3,
  "name": "PasteKit Lab",
  "version": "1.0.3",
  "description": "Paste anything. Watch the magic happen.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PasteKit Lab"
  },
  "options_page": "options.html",
  "devtools_page": "devtools.html",
  "icons": {
    "16": "PasteKitLab_16.png",
    "32": "PasteKitLab_32.png",
    "64": "PasteKitLab_64.png",
    "128": "PasteKitLab_128.png"
  },
  "permissions": [
    "commands",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8889/",
    "http://localhost:8889/"
  ],
  "optional_host_permissions": [
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+A"
      },
      "description": "Open PasteKitLab popup"
    },
    "open-options": {
      "suggested_key": {
        "default": "Alt+Shift+Z"
      },
      "description": "Open PasteKitLab options page"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https: http: ws://127.0.0.1:8889 ws://localhost:8889; frame-src 'self'; child-src 'self';"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}